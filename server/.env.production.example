# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
# Enforces WSS/HTTPS in production (leave true unless behind a proxy that strips TLS before Node)
ENFORCE_TLS=true

# ── CORS & URLs ───────────────────────────────────────────────────────────
# The public URL where your React frontend is hosted
CLIENT_URL=https://atomquest.dev

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────
# Your production database connection string (use connection pooling URL if available)
DATABASE_URL=postgresql://postgres:production_password@db.production.supabase.co:5432/postgres

# ── Redis (Distributed State & Pub/Sub) ───────────────────────────────────
# Point to AWS ElastiCache, Upstash, or your managed Redis instance
REDIS_HOST=production-redis-endpoint.cache.amazonaws.com
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_if_needed

# ── JWT Security ──────────────────────────────────────────────────────────
# MUST be a long cryptographically secure random string in production!
# e.g., generate with: openssl rand -base64 32
JWT_SECRET=YOUR_SUPER_SECRET_PRODUCTION_KEY
JWT_EXPIRES_IN=7d

# ── Mediasoup SFU (CRITICAL) ──────────────────────────────────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
# MUST BE THE PUBLIC IP OF YOUR SERVER! Without this, external clients get no audio/video.
MEDIASOUP_ANNOUNCED_IP=198.51.100.23
# Scale this to match your production server's CPU core count
MEDIASOUP_WORKERS=4
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=10100

# ── Storage (AWS S3) ──────────────────────────────────────────────────────
# Switch from local MinIO to real S3
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=atomquest-production
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
# The public URL format or CDN domain used to serve files to clients
FILE_PUBLIC_BASE_URL=https://cdn.atomquest.dev

# ── Recording (FFmpeg) ────────────────────────────────────────────────────
# Only needed if ffmpeg isn't in your system PATH
# FFMPEG_PATH=/usr/bin/ffmpeg
# RECORDING_LISTEN_IP=127.0.0.1
# RECORDING_RTP_PORT=5004
